# Keycloak Identity Service
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=dataspace
KEYCLOAK_CLIENT_ID=dso-node
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# TLS / mTLS Certificates
SSL_KEYFILE=infrastructure/certs/dso.key
SSL_CERTFILE=infrastructure/certs/dso.crt
SSL_CA_CERTS=infrastructure/certs/ca.crt

# Kafka Event Bus
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Federated Catalog
CATALOG_URL=http://localhost:8000

# Local Database
DATABASE_URL=sqlite:///data/dso.db

# Audit Logging
AUDIT_LOG_PATH=./audit/dso.log

# Participant Identity
PARTICIPANT_ID=dso-001
